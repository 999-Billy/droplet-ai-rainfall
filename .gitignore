# Virtual environment — never commit this, recreated via requirements.txt instead
droplet_env/

# LSTM model files specifically excluded — not used in deployment,
# and the .keras format plus scaler are not needed since LSTM is
# intentionally not served by the live API
models/lstm_model.keras
models/lstm_scaler.pkl

# Raw dataset — keep the cleaned CSV tracked, but not the original heavy .xls
data/*.xls

# Jupyter checkpoint files — auto-generated clutter
.ipynb_checkpoints/

# Python cache files
__pycache__/
*.pyc

# OS-specific files
.DS_Store
Thumbs.db